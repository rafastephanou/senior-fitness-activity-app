# Copy this file to `.env` and adjust as needed: `cp .env.example .env`
# docker compose reads these automatically.

# PostgreSQL credentials (used by the db and backend services)
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=seniorfit

# Secret used to sign JWT access tokens — change this for anything real
SECRET_KEY=dev-secret-change-me

# Host port for the frontend dev server. Change it if 5173 is already in use.
FRONTEND_PORT=5173
